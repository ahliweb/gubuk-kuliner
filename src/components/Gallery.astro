---
const images = [
  {
    src: "/assets/img/nasi_telur_dadar.png",
    alt: "Nasi Telur Dadar Sambal Cumi Teri",
    title: "Sajian Nasi Telur Dadar"
  },
  {
    src: "/assets/img/tahu_tek_tek.png",
    alt: "Tahu Tek-Tek",
    title: "Tahu Tek-Tek Gurih"
  },
  {
    src: "https://images.unsplash.com/photo-1596797038530-2c107229654b?q=80&w=600&auto=format&fit=crop",
    alt: "Kuliner Tradisional Indonesia",
    title: "Rempah Khas Pilihan"
  },
  {
    src: "https://images.unsplash.com/photo-1504674900247-0877df9cc836?q=80&w=600&auto=format&fit=crop",
    alt: "Menu Hemat Lengkap",
    title: "Sajian Piring Tradisional"
  }
];
---

<section id="galeri" class="py-16 md:py-24 bg-brand-bg relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
      <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-brand-secondary/10 text-brand-secondary uppercase tracking-wider">
        📸 Galeri Foto
      </span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-brand-text font-display leading-tight">
        Sajian Lezat Bikin Nagih
      </h2>
      <p class="text-base sm:text-lg text-brand-muted leading-relaxed">
        Lihat visualisasi kelezatan menu-menu andalan kami yang disiapkan dengan cinta dan bahan-bahan segar setiap hari.
      </p>
    </div>

    <!-- Gallery Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {images.map((img) => (
        <div class="group relative overflow-hidden rounded-3xl border border-brand-secondary/10 aspect-square bg-brand-surface shadow-sm hover:shadow-lg transition-all duration-300">
          <!-- Image -->
          <img 
            src={img.src} 
            alt={img.alt} 
            loading="lazy"
            width="400"
            height="400"
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" 
          />
          
          <!-- Hover Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-brand-text/80 via-brand-text/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-350 flex flex-col justify-end p-6">
            <span class="text-brand-primary text-xs font-bold uppercase tracking-wider mb-1">
              Gubuk Kuliner
            </span>
            <h3 class="text-brand-bg font-bold text-lg font-display">
              {img.title}
            </h3>
          </div>
        </div>
      ))}
    </div>

    <!-- Disclaimer / Note -->
    <div class="text-center mt-8">
      <p class="text-xs sm:text-sm text-brand-muted italic max-w-2xl mx-auto bg-brand-primary/10 border border-brand-primary/20 px-4 py-3 rounded-2xl">
        ℹ️ Beberapa gambar di atas adalah ilustrasi sajian. Foto asli menu dapat diperbarui oleh pemilik usaha sewaktu-waktu.
      </p>
    </div>

  </div>
</section>
