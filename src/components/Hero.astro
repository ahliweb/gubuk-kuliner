---
import { siteData } from '../data/site';
---

<section 
  id="hero" 
  class="relative overflow-hidden py-16 md:py-24 lg:py-32 bg-gradient-to-b from-brand-bg to-brand-bg/50"
>
  <!-- Decorative Background Blobs -->
  <div class="absolute -top-24 -left-24 w-96 h-96 bg-brand-primary/10 rounded-full blur-3xl -z-10"></div>
  <div class="absolute bottom-10 right-0 w-80 h-80 bg-brand-accent/5 rounded-full blur-3xl -z-10"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
      
      <!-- Text Column -->
      <div class="lg:col-span-7 space-y-8 text-left">
        
        <!-- Tagline Badge -->
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-2xl bg-brand-primary/15 text-brand-secondary border border-brand-primary/20 font-bold text-xs uppercase tracking-wider animate-pulse-slow">
          🍲 Rasa Rumahan, Harga Ramah
        </span>
        
        <!-- Headline -->
        <div class="space-y-4">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-brand-text leading-tight font-display">
            Makan Enak Mulai <span class="text-brand-secondary bg-brand-primary/20 px-2 py-0.5 rounded-lg border border-brand-primary/30">{siteData.priceStart}</span> di Gubuk Kuliner
          </h1>
          <p class="text-lg sm:text-xl text-brand-muted max-w-2xl leading-relaxed">
            Nikmati menu rumahan lezat seperti <strong class="text-brand-text">Nasi Telur Dadar Sambal Cumi/Teri</strong> dan <strong class="text-brand-text">Tahu Tek-Tek</strong>. Siap disantap hangat, halal, dan mengenyangkan!
          </p>
        </div>

        <!-- Badges Grid -->
        <div class="flex flex-wrap gap-2.5">
          <span class="px-3.5 py-1.5 rounded-full text-sm font-semibold bg-emerald-500/10 text-emerald-700 border border-emerald-500/20">
            ✅ Bahan Halal Terjamin
          </span>
          <span class="px-3.5 py-1.5 rounded-full text-sm font-semibold bg-brand-secondary/10 text-brand-secondary border border-brand-secondary/20">
            💵 Mulai {siteData.priceStart}
          </span>
          <span class="px-3.5 py-1.5 rounded-full text-sm font-semibold bg-brand-secondary/10 text-brand-secondary border border-brand-secondary/20">
            🌙 Buka s/d {siteData.openUntil}
          </span>
          <span class="px-3.5 py-1.5 rounded-full text-sm font-semibold bg-brand-secondary/10 text-brand-secondary border border-brand-secondary/20">
            🍽️ Makan di Tempat
          </span>
          <span class="px-3.5 py-1.5 rounded-full text-sm font-semibold bg-brand-secondary/10 text-brand-secondary border border-brand-secondary/20">
            🚗 Drive-Thru Praktis
          </span>
          <span class="px-3.5 py-1.5 rounded-full text-sm font-semibold bg-brand-secondary/10 text-brand-secondary border border-brand-secondary/20">
            📱 Pesan WA &amp; DP Dulu
          </span>
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 pt-2">
          <a 
            href={siteData.waLink} 
            target="_blank" 
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-3 px-8 py-4 rounded-2xl font-extrabold text-base bg-brand-secondary text-brand-bg hover:bg-brand-text active:scale-[0.98] shadow-lg hover:shadow-xl transition-all"
            aria-label="Pesan hidangan sekarang melalui WhatsApp"
          >
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.97C16.528 2.017 14.077 1.001 11.997 1c-5.439 0-9.867 4.372-9.87 9.802 0 1.63.482 3.224 1.393 4.634L2.527 20.89l5.093-1.316-1.077-.42zM17.91 14.3c-.324-.162-1.92-.949-2.218-1.059-.297-.109-.514-.162-.73.162-.217.324-.838 1.059-1.027 1.275-.19.216-.379.243-.703.08-1.785-.895-3.08-1.579-4.148-3.414-.282-.486-.062-.75.14-.993.183-.217.379-.486.568-.73.19-.243.253-.405.379-.675.127-.27.063-.514-.032-.676-.095-.162-.73-1.758-.999-2.407-.262-.63-.53-.54-.73-.55-.19-.01-.406-.01-.622-.01s-.568.081-.865.405c-.297.324-1.135 1.109-1.135 2.703 0 1.594 1.162 3.136 1.324 3.352.162.216 2.284 3.488 5.534 4.894 2.7.11 3.248-.88 3.248-.88s.27-1.162.378-1.568c.108-.405-.081-.622-.243-.784z" />
            </svg>
            Pesan Sekarang via WA
          </a>
          <a 
            href="#menu" 
            class="flex items-center justify-center gap-2 px-8 py-4 rounded-2xl font-bold text-base bg-brand-primary text-brand-text hover:bg-brand-primary/80 active:scale-[0.98] shadow-md hover:shadow-lg transition-all"
            aria-label="Lihat daftar menu lengkap"
          >
            📋 Lihat Menu Lengkap
          </a>
        </div>
        
      </div>

      <!-- Image Column (Interactive Flyer Composition) -->
      <div class="lg:col-span-5 relative flex items-center justify-center mt-10 lg:mt-0">
        
        <!-- Wavy/organic decorative yellow background blob -->
        <div class="absolute w-[320px] sm:w-[400px] h-[320px] sm:h-[400px] bg-brand-primary blob-organic-1 -z-10 animate-float opacity-80"></div>
        
        <!-- Interactive Stack -->
        <div class="relative w-full max-w-[340px] sm:max-w-[400px] aspect-square flex items-center justify-center">
          
          <!-- Dish 1: Nasi Telur Dadar (Top-Right) -->
          <div class="absolute top-2 right-2 w-[180px] sm:w-[220px] aspect-square group z-10 transition-transform duration-300 hover:scale-105 hover:z-30">
            <!-- Scribble SVG container -->
            <div class="absolute inset-[-12px] -z-10 bg-no-repeat bg-contain opacity-90" 
                 style="background-image: url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22 fill=%22none%22 stroke=%22%237A4A2E%22 stroke-width=%222%22 stroke-linecap=%22round%22%3E%3Cpath d=%22M15,40 C30,10 70,8 88,38 C98,58 90,85 62,88 C32,92 10,75 15,40 C20,15 65,22 82,45 C90,65 72,82 45,78%22/%3E%3C/svg%3E')">
            </div>
            <img 
              src="/assets/img/nasi_telur_dadar.png" 
              alt="Nasi Telur Dadar Sambal Cumi Teri" 
              width="220" 
              height="220" 
              class="w-full h-full object-cover rounded-full border-4 border-brand-bg shadow-lg" 
            />
            <!-- Label Tag -->
            <span class="absolute -bottom-2 -left-4 bg-brand-secondary text-brand-bg text-[10px] sm:text-xs font-bold px-2.5 py-1 rounded-full shadow-md rotate-[-6deg]">
              🍳 Telur Dadar Sambal Cumi
            </span>
          </div>

          <!-- Dish 2: Tahu Tek-Tek (Bottom-Left) -->
          <div class="absolute bottom-2 left-2 w-[170px] sm:w-[210px] aspect-square group z-20 transition-transform duration-300 hover:scale-105 hover:z-30">
            <!-- Scribble SVG container -->
            <div class="absolute inset-[-12px] -z-10 bg-no-repeat bg-contain opacity-90" 
                 style="background-image: url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22 fill=%22none%22 stroke=%22%237A4A2E%22 stroke-width=%222%22 stroke-linecap=%22round%22%3E%3Cpath d=%22M12,42 C28,15 72,12 85,35 C95,55 85,82 60,85 C35,88 15,70 12,42 C10,20 60,25 78,48 C85,65 72,80 50,75%22/%3E%3C/svg%3E')">
            </div>
            <img 
              src="/assets/img/tahu_tek_tek.png" 
              alt="Tahu Tek-Tek" 
              width="210" 
              height="210" 
              class="w-full h-full object-cover rounded-full border-4 border-brand-bg shadow-lg" 
            />
            <!-- Label Tag -->
            <span class="absolute -top-3 -right-2 bg-brand-primary text-brand-text text-[10px] sm:text-xs font-bold px-2.5 py-1 rounded-full shadow-md rotate-[4deg]">
              🥜 Tahu Tek-Tek Khas
            </span>
          </div>

          <!-- Decorative Arrow and Notes -->
          <div class="absolute -right-16 top-1/2 -translate-y-1/2 hidden xl:block w-24">
            <svg class="w-16 h-16 text-brand-secondary fill-none stroke-current stroke-2 animate-float" viewBox="0 0 100 100">
              <path d="M10,80 Q30,60 50,75 T90,30" stroke-dasharray="4,4"/>
              <path d="M80,38 L90,30 L80,22"/>
            </svg>
            <p class="handwritten text-xl text-brand-secondary rotate-12 -mt-4 text-center font-bold">Cobain Yuk!</p>
          </div>

        </div>

      </div>
      
    </div>
  </div>
</section>
