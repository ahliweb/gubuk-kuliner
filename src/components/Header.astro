---
import { siteData } from '../data/site';
---

<header 
  id="main-header" 
  class="sticky top-0 z-[100] w-full bg-brand-bg/90 backdrop-blur-md border-b border-brand-secondary/10 py-5 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between">
      
      <!-- Brand Logo -->
      <a href="/" class="flex items-center gap-3 group focus:outline-none focus:ring-2 focus:ring-brand-secondary rounded-lg" aria-label="Beranda Gubuk Kuliner">
        <img 
          src="/assets/img/logo.svg" 
          alt="Logo Gubuk Kuliner" 
          width="180" 
          height="72" 
          class="h-12 w-auto transition-transform duration-300 group-hover:scale-105" 
        />
      </a>

      <!-- Desktop Nav Links -->
      <nav class="hidden md:flex items-center gap-6 lg:gap-8">
        <a href="#menu" class="nav-link text-brand-text/90 hover:text-brand-secondary font-medium transition-colors">Menu</a>
        <a href="#keunggulan" class="nav-link text-brand-text/90 hover:text-brand-secondary font-medium transition-colors">Keunggulan</a>
        <a href="#cara-pesan" class="nav-link text-brand-text/90 hover:text-brand-secondary font-medium transition-colors">Cara Pesan</a>
        <a href="#galeri" class="nav-link text-brand-text/90 hover:text-brand-secondary font-medium transition-colors">Galeri</a>
        <a href="#lokasi" class="nav-link text-brand-text/90 hover:text-brand-secondary font-medium transition-colors">Lokasi</a>
        <a href="#faq" class="nav-link text-brand-text/90 hover:text-brand-secondary font-medium transition-colors">FAQ</a>
      </nav>

      <!-- Desktop Badge & CTA -->
      <div class="hidden md:flex items-center gap-4">
        <!-- Open Hours Badge -->
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-brand-primary/20 text-brand-secondary border border-brand-primary/30">
          <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
          Buka s/d {siteData.openUntil}
        </span>
        <!-- WA CTA -->
        <a 
          href={siteData.waLink} 
          target="_blank" 
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl font-bold text-sm bg-brand-secondary text-brand-bg hover:bg-brand-text active:scale-95 shadow-md hover:shadow-lg transition-all"
          aria-label="Hubungi kami melalui WhatsApp"
        >
          <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.97C16.528 2.017 14.077 1.001 11.997 1c-5.439 0-9.867 4.372-9.87 9.802 0 1.63.482 3.224 1.393 4.634L2.527 20.89l5.093-1.316-1.077-.42zM17.91 14.3c-.324-.162-1.92-.949-2.218-1.059-.297-.109-.514-.162-.73.162-.217.324-.838 1.059-1.027 1.275-.19.216-.379.243-.703.08-1.785-.895-3.08-1.579-4.148-3.414-.282-.486-.062-.75.14-.993.183-.217.379-.486.568-.73.19-.243.253-.405.379-.675.127-.27.063-.514-.032-.676-.095-.162-.73-1.758-.999-2.407-.262-.63-.53-.54-.73-.55-.19-.01-.406-.01-.622-.01s-.568.081-.865.405c-.297.324-1.135 1.109-1.135 2.703 0 1.594 1.162 3.136 1.324 3.352.162.216 2.284 3.488 5.534 4.894 2.7.11 3.248-.88 3.248-.88s.27-1.162.378-1.568c.108-.405-.081-.622-.243-.784z" />
          </svg>
          Pesan via WA
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button 
        id="mobile-menu-btn" 
        class="md:hidden flex items-center justify-center p-2 rounded-xl text-brand-text hover:bg-brand-primary/20 focus:outline-none focus:ring-2 focus:ring-brand-secondary transition-all"
        aria-expanded="false" 
        aria-controls="mobile-menu"
        aria-label="Buka Menu Navigasi"
        style="width: 44px; height: 44px;"
      >
        <!-- Burger Menu Icon -->
        <svg class="menu-icon w-6 h-6 stroke-current" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
        <!-- Close Menu Icon -->
        <svg class="close-icon w-6 h-6 stroke-current hidden" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

    </div>
  </div>

  <!-- Mobile Slide Down Menu Overlay -->
  <div 
    id="mobile-menu" 
    class="hidden md:hidden w-full bg-brand-bg border-b border-brand-secondary/15 animate-fade-in"
  >
    <div class="px-4 pt-3 pb-6 space-y-3 flex flex-col items-stretch">
      <a href="#menu" class="px-4 py-3 rounded-xl hover:bg-brand-primary/10 text-brand-text hover:text-brand-secondary font-medium transition-all">Menu</a>
      <a href="#keunggulan" class="px-4 py-3 rounded-xl hover:bg-brand-primary/10 text-brand-text hover:text-brand-secondary font-medium transition-all">Keunggulan</a>
      <a href="#cara-pesan" class="px-4 py-3 rounded-xl hover:bg-brand-primary/10 text-brand-text hover:text-brand-secondary font-medium transition-all">Cara Pesan</a>
      <a href="#galeri" class="px-4 py-3 rounded-xl hover:bg-brand-primary/10 text-brand-text hover:text-brand-secondary font-medium transition-all">Galeri</a>
      <a href="#lokasi" class="px-4 py-3 rounded-xl hover:bg-brand-primary/10 text-brand-text hover:text-brand-secondary font-medium transition-all">Lokasi</a>
      <a href="#faq" class="px-4 py-3 rounded-xl hover:bg-brand-primary/10 text-brand-text hover:text-brand-secondary font-medium transition-all">FAQ</a>
      
      <!-- Open Hours Indicator Mobile -->
      <div class="px-4 py-2 flex items-center gap-2">
        <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse"></span>
        <span class="text-sm font-semibold text-brand-secondary">Buka setiap hari s/d {siteData.openUntil}</span>
      </div>

      <!-- WA CTA Mobile -->
      <a 
        href={siteData.waLink} 
        target="_blank" 
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-2.5 px-6 py-3.5 rounded-xl font-bold bg-brand-secondary text-brand-bg hover:bg-brand-text active:scale-95 shadow-md transition-all text-center"
      >
        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.97C16.528 2.017 14.077 1.001 11.997 1c-5.439 0-9.867 4.372-9.87 9.802 0 1.63.482 3.224 1.393 4.634L2.527 20.89l5.093-1.316-1.077-.42zM17.91 14.3c-.324-.162-1.92-.949-2.218-1.059-.297-.109-.514-.162-.73.162-.217.324-.838 1.059-1.027 1.275-.19.216-.379.243-.703.08-1.785-.895-3.08-1.579-4.148-3.414-.282-.486-.062-.75.14-.993.183-.217.379-.486.568-.73.19-.243.253-.405.379-.675.127-.27.063-.514-.032-.676-.095-.162-.73-1.758-.999-2.407-.262-.63-.53-.54-.73-.55-.19-.01-.406-.01-.622-.01s-.568.081-.865.405c-.297.324-1.135 1.109-1.135 2.703 0 1.594 1.162 3.136 1.324 3.352.162.216 2.284 3.488 5.534 4.894 2.7.11 3.248-.88 3.248-.88s.27-1.162.378-1.568c.108-.405-.081-.622-.243-.784z" />
        </svg>
        Hubungi Kami via WhatsApp
      </a>
    </div>
  </div>
</header>
