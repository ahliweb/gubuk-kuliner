---
import { siteData } from '../data/site';
---

<section id="cara-pesan" class="py-16 md:py-24 bg-brand-surface relative overflow-hidden">
  <!-- Decorative background items -->
  <div class="absolute -right-24 top-1/2 w-72 h-72 bg-brand-primary/5 rounded-full blur-3xl -z-10"></div>
  <div class="absolute -left-24 bottom-0 w-80 h-80 bg-brand-accent/5 rounded-full blur-3xl -z-10"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
      <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-brand-secondary/10 text-brand-secondary uppercase tracking-wider">
        💡 Alur Mudah
      </span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-brand-text font-display leading-tight">
        Cara Praktis Memesan di Gubuk Kuliner
      </h2>
      <p class="text-base sm:text-lg text-brand-muted leading-relaxed">
        Pesan sekarang tanpa mengantre lama. Cukup ikuti langkah mudah berikut ini agar hidangan siap saat Anda tiba!
      </p>
    </div>

    <!-- Steps Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 relative">
      
      <!-- Connecting Line (Desktop Only) -->
      <div class="hidden lg:block absolute top-1/2 left-[12%] right-[12%] h-0.5 border-t-2 border-dashed border-brand-primary/45 -translate-y-[40px] -z-10"></div>
      
      {siteData.steps.map((step, index) => (
        <div class="relative group flex flex-col items-center text-center space-y-4 bg-brand-bg/40 p-6 rounded-3xl border border-brand-secondary/5 hover:border-brand-primary/30 transition-all duration-300">
          
          <!-- Number Badge -->
          <div class="relative flex items-center justify-center w-16 h-16 rounded-2xl bg-brand-primary text-brand-text font-display font-extrabold text-2xl shadow-md group-hover:bg-brand-secondary group-hover:text-brand-bg transition-colors duration-300">
            {step.num}
            <!-- Mini accent dot -->
            <span class="absolute -top-1 -right-1 w-3.5 h-3.5 rounded-full bg-brand-secondary border-2 border-brand-bg group-hover:bg-brand-accent"></span>
          </div>

          <!-- Step Info -->
          <div class="space-y-2">
            <h3 class="text-lg font-extrabold text-brand-text font-display group-hover:text-brand-secondary transition-colors duration-300">
              {step.title}
            </h3>
            <p class="text-sm text-brand-muted leading-relaxed">
              {step.desc}
            </p>
          </div>

          <!-- Decorative Arrow (Mobile only between items) -->
          {index < siteData.steps.length - 1 && (
            <div class="md:hidden flex items-center justify-center pt-2">
              <svg class="w-6 h-6 text-brand-primary stroke-current fill-none stroke-2 animate-bounce" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 13l-7 7-7-7m14-6l-7 7-7-7" />
              </svg>
            </div>
          )}

        </div>
      ))}
    </div>

    <!-- Quick WA Button below steps -->
    <div class="text-center mt-12">
      <a 
        href={siteData.waLink}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-3 px-8 py-4 rounded-2xl font-extrabold text-base bg-brand-secondary text-brand-bg hover:bg-brand-text active:scale-95 shadow-lg transition-all"
        aria-label="Pesan via WhatsApp sekarang"
      >
        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.97C16.528 2.017 14.077 1.001 11.997 1c-5.439 0-9.867 4.372-9.87 9.802 0 1.63.482 3.224 1.393 4.634L2.527 20.89l5.093-1.316-1.077-.42zM17.91 14.3c-.324-.162-1.92-.949-2.218-1.059-.297-.109-.514-.162-.73.162-.217.324-.838 1.059-1.027 1.275-.19.216-.379.243-.703.08-1.785-.895-3.08-1.579-4.148-3.414-.282-.486-.062-.75.14-.993.183-.217.379-.486.568-.73.19-.243.253-.405.379-.675.127-.27.063-.514-.032-.676-.095-.162-.73-1.758-.999-2.407-.262-.63-.53-.54-.73-.55-.19-.01-.406-.01-.622-.01s-.568.081-.865.405c-.297.324-1.135 1.109-1.135 2.703 0 1.594 1.162 3.136 1.324 3.352.162.216 2.284 3.488 5.534 4.894 2.7.11 3.248-.88 3.248-.88s.27-1.162.378-1.568c.108-.405-.081-.622-.243-.784z" />
        </svg>
        Pesan Sekarang via WA
      </a>
    </div>

  </div>
</section>
