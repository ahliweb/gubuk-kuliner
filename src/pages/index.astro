---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import MenuCard from '../components/MenuCard.astro';
import NutritionFacts from '../components/NutritionFacts.astro';
import OrderSteps from '../components/OrderSteps.astro';
import Gallery from '../components/Gallery.astro';
import FAQ from '../components/FAQ.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import Footer from '../components/Footer.astro';
import { siteData } from '../data/site';
import { getNutritionByMenuId } from '../data/nutrition';
---

<BaseLayout>
  <!-- Sticky Header -->
  <Header slot="header" />

  <!-- Hero Section -->
  <Hero />

  <!-- Menu Section -->
  <section id="menu" class="py-16 md:py-24 bg-brand-surface relative overflow-hidden">
    <div class="absolute -left-24 top-1/2 w-80 h-80 bg-brand-primary/5 rounded-full blur-3xl -z-10 animate-float"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      
      <!-- Section Header -->
      <div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
        <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-brand-secondary/10 text-brand-secondary uppercase tracking-wider">
          🍽️ Pilihan Menu
        </span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-brand-text font-display leading-tight">
          Menu Unggulan Gubuk Kuliner
        </h2>
        <p class="text-base sm:text-lg text-brand-muted leading-relaxed">
          Sajian istimewa ala rumahan dengan bumbu rempah pilihan, dijamin menggugah selera dan pas di dompet Anda.
        </p>
      </div>

      <!-- Menu Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {siteData.menus.map((menu) => {
          const nutrition = getNutritionByMenuId(menu.id);
          return (
            <div class="flex flex-col">
              <MenuCard 
                title={menu.title}
                description={menu.description}
                price={menu.price}
                image={menu.image}
                badge={menu.badge}
                waLink={menu.waLink}
              />
              {nutrition && <NutritionFacts nutrition={nutrition} />}
            </div>
          );
        })}
      </div>

    </div>
  </section>

  <!-- Advantages Section -->
  <section id="keunggulan" class="py-16 md:py-24 bg-brand-bg relative overflow-hidden">
    <!-- Wavy visual shape divider or decorative blobs -->
    <div class="absolute -right-24 bottom-12 w-80 h-80 bg-brand-accent/5 rounded-full blur-3xl -z-10 animate-float-reverse"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Section Header -->
      <div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
        <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-brand-secondary/10 text-brand-secondary uppercase tracking-wider">
          ⭐ Kenapa Kami?
        </span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-brand-text font-display leading-tight">
          Keunggulan Gubuk Kuliner
        </h2>
        <p class="text-base sm:text-lg text-brand-muted leading-relaxed">
          Kami berkomitmen memberikan cita rasa terbaik dengan pelayanan praktis dan harga bersahabat untuk semua kalangan.
        </p>
      </div>

      <!-- Advantages Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {siteData.advantages.map((adv) => (
          <div class="group bg-brand-surface p-8 rounded-3xl border border-brand-secondary/10 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <!-- Icon/Icon Placeholder -->
            <div class="flex items-center justify-center w-12 h-12 rounded-2xl bg-brand-primary/20 text-brand-secondary font-bold text-xl mb-6 group-hover:bg-brand-primary group-hover:text-brand-text transition-colors duration-300">
              ✓
            </div>
            
            <!-- Advantage Info -->
            <div class="space-y-2">
              <h3 class="text-lg font-bold text-brand-text group-hover:text-brand-secondary transition-colors duration-300 font-display">
                {adv.title}
              </h3>
              <p class="text-sm sm:text-base text-brand-muted leading-relaxed">
                {adv.desc}
              </p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- Alur Cara Pesan -->
  <OrderSteps />

  <!-- Galeri Sajian -->
  <Gallery />

  <!-- Accordion FAQ -->
  <FAQ />

  <!-- Floating WA CTA -->
  <WhatsAppButton />

  <!-- Footer Location & Map -->
  <Footer slot="footer" />
</BaseLayout>
