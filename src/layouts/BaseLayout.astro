---
import { siteData } from '../data/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = siteData.seoTitle, 
  description = siteData.seoDescription 
} = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Restaurant",
  "name": "Gubuk Kuliner",
  "image": `${siteData.website}/assets/img/og-image.svg`,
  "@id": `${siteData.website}/#restaurant`,
  "url": siteData.website,
  "telephone": `+${siteData.whatsapp}`,
  "priceRange": "Rp15.000 - Rp30.000",
  "menu": `${siteData.website}/#menu`,
  "servesCuisine": "Indonesian",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": siteData.address,
    "addressLocality": "Madurejo",
    "addressRegion": "Kotawaringin Barat, Kalimantan Tengah",
    "addressCountry": "ID"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "-2.701618",
    "longitude": "111.6315829"
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
      "Saturday",
      "Sunday"
    ],
    "opens": "09:00",
    "closes": "21:00"
  }
};
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={siteData.website} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#D9B43E" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="restaurant" />
    <meta property="og:url" content={siteData.website} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteData.website}/assets/img/og-image.svg`} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={siteData.website} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={`${siteData.website}/assets/img/og-image.svg`} />

    <!-- Preconnect Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Google Fonts: Outfit (Display), Plus Jakarta Sans (Body), Caveat (Handwritten) -->
    <link 
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@700&family=Outfit:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" 
      rel="stylesheet" 
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="bg-brand-bg text-brand-text grid-bg min-h-screen flex flex-col antialiased">
    <!-- Skip to Content Link -->
    <a 
      href="#main-content" 
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[999] focus:px-4 focus:py-2 focus:bg-brand-secondary focus:text-brand-bg focus:font-semibold focus:rounded-xl focus:shadow-lg focus:outline-none"
    >
      Lompati ke Konten Utama
    </a>

    <slot name="header" />
    
    <main id="main-content" class="flex-grow">
      <slot />
    </main>

    <slot name="footer" />

    <!-- JavaScript Bundle (Vanilla JS) -->
    <script src="../scripts/main.js"></script>
  </body>
</html>
